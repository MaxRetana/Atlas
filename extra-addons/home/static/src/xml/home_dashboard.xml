<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="home.HomeDashboardMain" owl="1">
        <div class="o_home_dashboard container-fluid p-5 bg-white" style="min-height: 100vh;">
            
            <div class="text-center mb-5 mt-4">
                <h2 class="fw-bold text-dark">¿Qué vamos a hacer hoy?</h2>
                <div class="d-flex justify-content-center mt-4">
                    <div class="input-group shadow-sm" style="max-width: 500px; border-radius: 25px; overflow: hidden;">
                        <span class="input-group-text bg-white border-end-0 ps-4">
                            <i class="fa fa-search text-muted"/>
                        </span>
                        <input type="text" 
                               class="form-control border-start-0 fs-5 py-3" 
                               placeholder="Escribe para buscar aplicaciones..."
                               t-ref="searchInput"
                               t-on-input="onSearchInput"
                               t-att-value="state.searchTerm"/>
                    </div>
                </div>
            </div>

            <div class="row g-4 justify-content-center">
                <t t-foreach="filteredApps" t-as="app" t-key="app.id">
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2 text-center" 
                         t-on-click="() => this.openApp(app)">
                        <div class="app-card rounded-4 p-4 h-100 shadow-none">
                            <div class="icon-wrapper mb-3 rounded-3 d-flex align-items-center justify-content-center m-auto"
                                 style="width: 70px; height: 70px; background: #f8f9fa;">
                                
                                <t t-if="app.icon_type === 'fontawesome'">
                                    <i t-attf-class="fa #{app.fa_icon} text-primary" style="font-size: 2rem;"/>
                                </t>
                                <t t-else="">
                                    <img t-if="app.custom_icon" 
                                         t-att-src="`/web/image/home.home/${app.id}/custom_icon`"
                                         style="width: 100%; height: 100%; object-fit: contain; padding: 8px;"/>
                                </t>
                            </div>
                            <span class="fw-bold text-dark text-truncate d-block">
                                <t t-esc="app.name"/>
                            </span>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>

